# Mentra root .env example — copy to .env and adjust for local dev.

# ---- App ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=5173
WEB_APP_ORIGIN=http://localhost:5173

# ---- MySQL (local Docker) ----
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=mentra
MYSQL_USER=mentra
MYSQL_PASSWORD=mentra_dev_pw
MYSQL_ROOT_PASSWORD=mentra_root_pw
DATABASE_URL=mysql://mentra:mentra_dev_pw@mysql:3306/mentra

# ---- Redis (local Docker) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Auth ----
JWT_ACCESS_SECRET=dev_access_change_me_at_least_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_COOKIE_SECRET=dev_refresh_change_me_at_least_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- OAuth (leave empty in early dev) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM="Mentra <noreply@localhost>"

# ---- Resume upload (stored on local disk) ----
RESUME_STORAGE_DIR=var/uploads
RESUME_MAX_BYTES=5242880
PROFILE_DEFAULT_TIMEZONE=Asia/Kolkata

# ---- Assessment (module 03) ----
ASSESSMENT_SCORING_STRATEGY=default
ASSESSMENT_SWEEP_INTERVAL_SECONDS=30
ASSESSMENT_INITIAL_TEMPLATE_ID=initial
ASSESSMENT_QUESTION_OPTION_SHUFFLE=true

# ---- Dashboard (module 04) ----
DASHBOARD_RECOMMENDER_STRATEGY=default
DASHBOARD_NEXT_STEPS_LIMIT=5

# ---- Roadmap (module 05) ----
ROADMAP_GENERATOR_STRATEGY=default
ROADMAP_AUTO_REGEN_THROTTLE_SECONDS=21600
ROADMAP_MAX_WEEKS=16
ROADMAP_MIN_ITEMS_PER_WEEK=3
ROADMAP_MAX_ITEMS_PER_WEEK=8
ROADMAP_GENERATOR_TIMEOUT_MS=5000
# Topic subtopics + completion test (AI generated on demand, cached in DB)
ROADMAP_SUBTOPICS_MIN=4
ROADMAP_SUBTOPICS_MAX=12
ROADMAP_TEST_QUESTIONS_PER_SUBTOPIC=2
ROADMAP_TEST_MAX_QUESTIONS=40
ROADMAP_TEST_PASS_PERCENT=70

# ---- Telegram (outbound only) ----
TELEGRAM_BOT_TOKEN=

# ---- AI (Groq, OpenAI-compatible) — personalized assignments + roadmaps ----
AI_API_KEY=gsk_your_groq_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_TIMEOUT_MS=30000
AI_MAX_TOKENS=4096

# Use the AI roadmap generator (set to `default` for the deterministic one).
ROADMAP_GENERATOR_STRATEGY=ai

# ---- Live sessions (module 06) — self-hosted LiveKit SFU ----
# LIVEKIT_URL is the in-network control-plane URL the API uses (RoomServiceClient).
# LIVEKIT_WS_URL is the PUBLIC ws(s) URL the browser connects to (returned in join-token).
# The API key/secret must match infra/livekit/livekit.yaml.
LIVEKIT_URL=http://livekit:7880
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_chars_xxxx
LIVEKIT_TOKEN_TTL_SECONDS=21600

# ---- Recordings storage: Cloudflare R2 (S3-compatible) ----
# From R2 → Manage R2 API Tokens (Object Read & Write, scoped to your bucket). Region is
# always 'auto'. R2_PUBLIC_BASE_URL = the public CDN custom domain serving the HLS files.
# Leave empty to keep the recordings pipeline disabled. Put real secrets in .env only.
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mentra-recordings
R2_PUBLIC_BASE_URL=

# ---- Web (Vite) ----
# Public LiveKit ws URL for the browser (fallback; the join-token response is primary).
VITE_LIVEKIT_WS_URL=ws://localhost:7880

