# Mentra web (Vite) — copy to .env.local for local dev.

# API base URL. Leave empty to default to the current host on port 4000.
VITE_API_URL=

# Public LiveKit websocket URL the browser connects to for live sessions.
# This is a fallback — the API's join-token response carries the authoritative wsUrl.
VITE_LIVEKIT_WS_URL=ws://localhost:7880
