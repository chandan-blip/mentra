{
  "name": "@mentra/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "set -a; [ -f ../../.env ] && . ../../.env; set +a; tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "start": "set -a; [ -f ../../.env ] && . ../../.env; set +a; node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(lint skipped until eslint wired up)\"",
    "db:migrate": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma migrate dev",
    "db:deploy": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma migrate deploy",
    "db:studio": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma studio",
    "db:seed": "set -a; [ -f ../../.env ] && . ../../.env; set +a; tsx prisma/seed.ts",
    "db:seed:mentors": "set -a; [ -f ../../.env ] && . ../../.env; set +a; tsx prisma/seed-mentors.ts",
    "db:generate": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@mentra/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.25.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.9.2",
    "mysql2": "^3.22.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@mentra/config": "workspace:*",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
