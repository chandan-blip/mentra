// Mentra — Prisma schema
// Modules add their own models here as they ship.
// Migration policy: one DDL change per migration file (see architecture §7).

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  name          String
  role          Role       @default(student)
  roleId        String? // RBAC role (AccessRole.id); null falls back to a default
  planId        String? // subscription (Plan.id); null falls back to the default plan
  status        UserStatus @default(active)
  emailVerified Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  identities              AuthIdentity[]
  sessions                Session[]
  studentProfile          StudentProfile?
  notificationPreferences NotificationPreferences?
}

// --- RBAC + subscriptions (no DB foreign keys; ids stored as plain columns) ---

model Module {
  key         String   @id
  label       String
  description String?  @db.Text
  icon        String?  @db.VarChar(64)
  route       String?
  placement   String   @default("sidebar") @db.VarChar(16)
  role        String?  @db.VarChar(64)
  parentKey   String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

// Named AccessRole in Prisma to avoid clashing with the existing `Role` enum.
model AccessRole {
  id          String   @id
  label       String
  description String?  @db.VarChar(500)
  isAdmin     Boolean  @default(false)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("Role")
}

model RolePermission {
  roleId    String
  moduleKey String
  canRead   Boolean @default(true)
  canWrite  Boolean @default(false)

  @@id([roleId, moduleKey])
}

model Plan {
  id          String   @id
  name        String
  description String?  @db.VarChar(500)
  priceCents  Int      @default(0)
  active      Boolean  @default(true)
  isDefault   Boolean  @default(false)
  roleId      String? // target role (AccessRole.id); null = available to all roles
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model PlanModule {
  planId    String
  moduleKey String

  @@id([planId, moduleKey])
}

model RecommendationLog {
  id          String    @id @default(cuid())
  userId      String
  shownAt     DateTime  @default(now())
  source      String
  recId       String
  payload     Json
  shownIn     String
  actedOn     Boolean   @default(false)
  actedAt     DateTime?
  dismissedAt DateTime?

  @@index([userId, shownAt])
  @@index([recId])
}

// --- Roadmap (module 05) ---

model Roadmap {
  id                  String        @id @default(cuid())
  userId              String
  status              RoadmapStatus @default(active)
  generatedBy         String
  basisAttemptId      String?
  basisProfileVersion Int?
  totalWeeks          Int
  startedOn           DateTime      @default(now())
  archivedAt          DateTime?
  notes               String?       @db.Text

  // "one active roadmap per user" enforced via a generated activeKey + unique index.
  @@index([userId])
}

model RoadmapWeek {
  id         String    @id @default(cuid())
  roadmapId  String
  weekNumber Int
  title      String
  theme      String?
  startsOn   DateTime?
  endsOn     DateTime?

  @@unique([roadmapId, weekNumber])
  @@index([roadmapId])
}

model RoadmapItem {
  id           String            @id @default(cuid())
  weekId       String
  order        Int
  type         RoadmapItemType
  title        String            @db.VarChar(255)
  description  String?           @db.Text
  skillIds     Json?
  estimatedMin Int?
  contentRef   Json?
  dependsOnIds Json?
  status       RoadmapItemStatus @default(locked)
  completedAt  DateTime?

  @@unique([weekId, order])
  @@index([weekId, status])
}

enum RoadmapStatus {
  active
  archived
  superseded
}

enum RoadmapItemType {
  topic
  project
  assessment
  session
  reading
  practice
}

enum RoadmapItemStatus {
  locked
  available
  in_progress
  completed
  skipped
}

// Comprehensive breakdown of a `topic` item — every subtopic a student needs to
// learn, so they never have to figure out the scope themselves. Generated by the
// AI on demand (when the topic is first opened) and cached. One row per subtopic.
model RoadmapSubtopic {
  id           String   @id @default(cuid())
  roadmapId    String
  itemId       String
  order        Int
  title        String   @db.VarChar(255)
  description  String?  @db.Text
  estimatedMin Int?
  generatedBy  String
  createdAt    DateTime @default(now())

  @@unique([itemId, order])
  @@index([roadmapId])
}

// A topic-completion test. Essential data scoped by user/roadmap/topic. Questions
// are AI-generated on demand when the student starts the test, then cached. A
// generated `openKey` enforces one open (non-completed) test per (user, topic).
model RoadmapTest {
  id             String            @id @default(cuid())
  userId         String
  roadmapId      String
  itemId         String
  status         RoadmapTestStatus @default(ready)
  model          String
  totalQuestions Int               @default(0)
  maxScore       Int               @default(0)
  passPercent    Int
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())

  // "one open test per (user, topic)" enforced via a generated openKey + unique index.
  @@index([userId, itemId])
}

enum RoadmapTestStatus {
  ready
  in_progress
  completed
}

// One row per test question (never a JSON blob of all questions). `options`/`correct`
// are inherent per-question arrays. `subtopicId` ties the question to the subtopic it
// probes so coverage spans the whole topic.
model RoadmapTestQuestion {
  id          String                  @id @default(cuid())
  testId      String
  subtopicId  String?
  order       Int
  type        RoadmapTestQuestionType
  body        String                  @db.Text
  options     Json
  correct     Json
  explanation String?                 @db.Text
  points      Int                     @default(1)

  @@unique([testId, order])
  @@index([testId])
}

enum RoadmapTestQuestionType {
  single_choice
  multi_choice
}

// One row per submitted answer.
model RoadmapTestAnswer {
  id            String   @id @default(cuid())
  testId        String
  questionId    String
  selected      Json
  isCorrect     Boolean  @default(false)
  pointsAwarded Int      @default(0)
  answeredAt    DateTime @default(now())

  @@unique([testId, questionId])
}

// Marks for a topic test, in a dedicated table keyed by user/test/topic/roadmap.
// One row per attempt so retake history is preserved.
model RoadmapTestResult {
  id             String   @id @default(cuid())
  userId         String
  testId         String
  roadmapId      String
  itemId         String
  attemptNumber  Int      @default(1)
  score          Int
  maxScore       Int
  percent        Int
  correctCount   Int
  totalQuestions Int
  passed         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId, roadmapId, itemId])
  @@index([testId])
}

// Personalized onboarding assignment, generated once per student by the AI and
// cached. `spec` holds the AI task set; `responses` the student's answers.
model Assignment {
  id          String           @id @default(cuid())
  userId      String
  status      AssignmentStatus @default(ready)
  model       String
  spec        Json
  responses   Json?
  score       Int?
  createdAt   DateTime         @default(now())
  completedAt DateTime?
  updatedAt   DateTime         @default(now()) @updatedAt

  // "one open assignment per user" enforced via a generated openKey + unique index.
  @@index([userId])
}

enum AssignmentStatus {
  ready
  completed
}

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  avatarUrl String? @db.VarChar(512)
  bio       String? @db.VarChar(500)

  country  String? @db.VarChar(100)
  city     String? @db.VarChar(120)
  timezone String  @default("Asia/Kolkata") @db.VarChar(64)

  educationLevel EducationLevel?
  collegeName    String?         @db.VarChar(200)
  graduationYear Int?

  experienceLevel ExperienceLevel?
  currentRole     String?          @db.VarChar(150)
  currentCompany  String?          @db.VarChar(150)

  goal                 CareerGoal?
  preferredCompanyType Json?
  targetRoles          Json?
  studyHoursPerDay     Int?

  techStack Json?

  githubUrl    String? @db.VarChar(512)
  linkedinUrl  String? @db.VarChar(512)
  portfolioUrl String? @db.VarChar(512)
  twitterUrl   String? @db.VarChar(512)

  resumeFileKey    String?   @db.VarChar(512)
  resumeUploadedAt DateTime?

  // Storage key for an uploaded profile picture (avatarUrl holds the servable URL).
  avatarFileKey String? @db.VarChar(512)

  onboardingStep     Int     @default(0)
  onboardingComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([onboardingComplete])
}

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailDailyTasks       Boolean @default(true)
  emailWeeklyReview     Boolean @default(true)
  emailSessionReminders Boolean @default(true)
  emailAnnouncements    Boolean @default(true)
  inAppEnabled          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model FeatureFlag {
  key         String   @id @db.VarChar(191)
  enabled     Boolean  @default(true)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

// --- Assessment (module 03) ---

model Skill {
  id        String        @id
  label     String
  category  SkillCategory
  parentId  String?
  parent    Skill?        @relation("SkillTree", fields: [parentId], references: [id])
  children  Skill[]       @relation("SkillTree")
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  questions QuestionSkill[]
  scores    SkillScore[]

  @@index([category])
}

model Question {
  id          String       @id @default(cuid())
  type        QuestionType
  body        String       @db.Text
  options     Json?
  correct     Json
  explanation String?      @db.Text
  difficulty  Int
  active      Boolean      @default(true)
  authoredBy  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt

  skills  QuestionSkill[]
  answers AssessmentAnswer[]

  @@index([type, active, difficulty])
}

model QuestionSkill {
  questionId String
  skillId    String
  weight     Int      @default(1)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([questionId, skillId])
  @@index([skillId])
}

model AssessmentTemplate {
  id             String       @id
  name           String
  description    String?      @db.VarChar(500)
  type           TemplateType
  questionCount  Int
  timeLimitSec   Int
  selectionRules Json
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  attempts AssessmentAttempt[]
}

model AssessmentAttempt {
  id                String             @id @default(cuid())
  userId            String
  templateId        String
  status            AttemptStatus
  startedAt         DateTime           @default(now())
  expiresAt         DateTime
  completedAt       DateTime?
  totalScore        Float?
  durationSec       Int?
  questionsSnapshot Json
  metadata          Json?
  template          AssessmentTemplate @relation(fields: [templateId], references: [id])
  answers           AssessmentAnswer[]

  // NOTE: the "one in-progress per (userId, templateId)" rule is enforced in the
  // DB by a generated `inProgressKey` column + unique index (see migration
  // 202605250012/13). That column is intentionally omitted here — Prisma can't
  // model STORED generated columns and runtime uses raw SQL, not the client.
  @@index([userId, status])
  @@index([expiresAt, status])
}

model AssessmentAnswer {
  id          String            @id @default(cuid())
  attemptId   String
  questionId  String
  selected    Json
  isCorrect   Boolean?
  timeSpentMs Int               @default(0)
  answeredAt  DateTime          @default(now())
  attempt     AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question    Question          @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model SkillScore {
  id            String   @id @default(cuid())
  userId        String
  skillId       String
  score         Float
  confidence    Float
  lastAttemptId String?
  updatedAt     DateTime @updatedAt
  skill         Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
}

model SkillScoreHistory {
  id         String   @id @default(cuid())
  userId     String
  skillId    String
  score      Float
  confidence Float
  source     String
  recordedAt DateTime @default(now())

  @@index([userId, skillId, recordedAt])
}

model AuthIdentity {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   AuthProvider
  providerId String
  createdAt  DateTime     @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  familyId         String
  rememberMe       Boolean   @default(true)
  userAgent        String?
  ip               String?
  revokedAt        DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

enum Role {
  student
  mentor
  admin
}

enum UserStatus {
  pending
  active
  suspended
}

enum AuthProvider {
  email
  google
  github
}

enum EducationLevel {
  high_school
  undergrad
  postgrad
  doctoral
  working_professional
  self_taught
}

enum ExperienceLevel {
  none
  intern
  under_one
  one_to_three
  three_to_five
  five_plus
}

enum CareerGoal {
  first_job
  switch_company
  fang_prep
  startup_join
  freelance
  upskill
}

enum CompanyType {
  startup
  mnc
  product
  service
  government
  remote
}

enum SkillCategory {
  language
  framework
  tool
  concept
  dsa
  system_design
  soft_skill
  domain
}

enum QuestionType {
  single_choice
  multi_choice
  numeric
  short_text
}

enum TemplateType {
  initial
  periodic
  topic
}

enum AttemptStatus {
  in_progress
  completed
  abandoned
  auto_completed
}

// --- Live sessions (mentor broadcast + student attend) ---
// Media runs on a self-hosted LiveKit SFU; Mentra only mints room tokens and
// records interaction analytics. No DB foreign keys; ids are plain columns.

model LiveSession {
  id              String    @id @default(cuid())
  mentorId        String // User.id of the broadcasting mentor (owner)
  title           String
  topic           String
  status          String    @default("scheduled") @db.VarChar(16) // scheduled | live | ended | canceled
  scheduledFor    DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  livekitRoom     String    @unique // LiveKit room name, e.g. "ls_<id>"
  currentViewers  Int       @default(0)
  peakViewers     Int       @default(0)
  // 'live' = recorded from a LiveKit broadcast; 'upload' = mentor-uploaded video.
  source          String    @default("live") @db.VarChar(16)
  // Recording: status + public HLS URL + LiveKit egress id (null for uploads).
  recordingStatus String?   @db.VarChar(32)
  recordingUrl    String?   @db.Text
  egressId        String?
  // Playback duration (seconds), filled by the transcode worker via ffprobe.
  durationSeconds Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@index([mentorId])
  @@index([status])
  @@index([scheduledFor])
}

// One row per join/leave interval (robust to reconnects / multi-tab). A user's
// attended duration for a session is SUM(attendedSeconds). Driven authoritatively
// by LiveKit webhooks (participant_joined / participant_left / room_finished).
model SessionParticipant {
  id              String    @id @default(cuid())
  sessionId       String
  userId          String
  roleAtJoin      String    @db.VarChar(16) // mentor | student
  joinedAt        DateTime  @default(now())
  leftAt          DateTime?
  attendedSeconds Int       @default(0) // filled when leftAt is set
  createdAt       DateTime  @default(now())

  @@index([sessionId])
  @@index([userId])
  @@index([sessionId, userId])
}

model ChatMessage {
  id           String   @id @default(cuid())
  sessionId    String
  authorUserId String
  authorName   String // denormalized snapshot of the author's name at send time
  body         String   @db.Text
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([sessionId, createdAt])
}

// Per-user resume position for a session recording (Netflix-style "continue watching").
// One row per (user, session); upserted as the student watches.
model WatchProgress {
  id              String   @id @default(cuid())
  userId          String
  sessionId       String
  positionSeconds Int      @default(0)
  updatedAt       DateTime @default(now()) @updatedAt

  @@unique([userId, sessionId])
}

// Job postings surfaced to students on the Jobs board. Two origins (`source`):
// `ai` — discovered from the live job market by the AI ingest (see jobs.ai.ts),
// `hr` — posted by an HR user from the HR Jobs module. `skills` is a JSON string[]
// matched against the student's tech stack to rank the board per profile.
model Job {
  id              String   @id @default(cuid())
  title           String   @db.VarChar(200)
  company         String   @db.VarChar(200)
  location        String?  @db.VarChar(200)
  locationType    String   @default("onsite") @db.VarChar(16) // onsite | remote | hybrid
  employmentType  String   @default("full-time") @db.VarChar(16) // full-time | part-time | internship | contract
  experienceLevel String   @default("entry") @db.VarChar(16) // entry | mid | senior
  description     String   @db.Text
  skills          Json? // string[] of required skills
  targetRole      String?  @db.VarChar(120)
  salary          String?  @db.VarChar(120)
  applyUrl        String?  @db.VarChar(500)
  source          String   @default("ai") @db.VarChar(16) // ai | hr
  createdBy       String? // HR user id when source = hr; null for ai
  status          String   @default("open") @db.VarChar(16) // open | closed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([status])
  @@index([source])
}

// --- Marketing: Leads CRM + lists + AI (Vapi) calling ---

// A sales/marketing lead owned by a marketing user. Holds the full contact + deal
// profile; `tags` is a JSON string[]. Leads are grouped into lists (LeadListMember)
// to run bulk actions (AI calling, email) against them.
model Lead {
  id              String    @id @default(cuid())
  ownerId         String
  firstName       String?   @db.VarChar(120)
  lastName        String?   @db.VarChar(120)
  email           String?   @db.VarChar(255)
  phone           String?   @db.VarChar(40)
  company         String?   @db.VarChar(200)
  jobTitle        String?   @db.VarChar(160)
  status          String    @default("new") @db.VarChar(20) // new|contacted|qualified|proposal|won|lost
  source          String?   @db.VarChar(40)
  value           Int? // deal value, minor units (e.g. cents)
  website         String?   @db.VarChar(500)
  linkedinUrl     String?   @db.VarChar(500)
  city            String?   @db.VarChar(120)
  country         String?   @db.VarChar(120)
  timezone        String?   @db.VarChar(64)
  notes           String?   @db.Text
  tags            Json? // string[]
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@index([ownerId])
}

// A named list/segment of leads. Bulk actions are performed per list.
model LeadList {
  id          String   @id @default(cuid())
  ownerId     String
  name        String   @db.VarChar(160)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

// Membership join: a lead can belong to many lists (deduped per list).
model LeadListMember {
  id      String   @id @default(cuid())
  listId  String
  leadId  String
  addedAt DateTime @default(now())

  @@unique([listId, leadId])
}

// One AI phone call placed via Vapi against a lead (optionally as part of a list run).
// `vapiCallId` ties it to the provider; the Vapi webhook fills status/summary/transcript.
model LeadCall {
  id           String    @id @default(cuid())
  ownerId      String
  leadId       String
  listId       String?
  vapiCallId   String?
  status       String    @default("queued") @db.VarChar(24) // queued|ringing|in-progress|ended|failed
  endedReason  String?   @db.VarChar(120)
  summary      String?   @db.Text
  transcript   String?   @db.MediumText
  recordingUrl String?   @db.VarChar(1000)
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([vapiCallId])
  @@index([ownerId])
}

// --- Learning (test series) ---
// Categories are AI-generated per student from their roadmap + profile; each category
// is a Beginner→Intermediate→Advanced ladder of MCQ tests. Detached from roadmap
// completion — students can take any test regardless of roadmap progress. Runtime
// queries use mysql2 (see modules/learning), not Prisma Client.

model LearningCategory {
  id          String   @id @default(cuid())
  userId      String
  slug        String
  title       String
  description String   @db.Text
  skillTags   Json
  icon        String?  @db.VarChar(64)
  order       Int      @default(0)
  generatedBy String
  createdAt   DateTime @default(now())

  @@unique([userId, slug])
  @@index([userId])
}

model LearningTest {
  id             String    @id @default(cuid())
  userId         String
  categoryId     String
  difficulty     String // beginner|intermediate|advanced (ENUM in SQL)
  order          Int       @default(0)
  title          String
  model          String?
  totalQuestions Int       @default(0)
  maxScore       Int       @default(0)
  passPercent    Int       @default(70)
  generatedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([categoryId])
  @@index([userId])
}

model LearningTestQuestion {
  id          String  @id @default(cuid())
  testId      String
  order       Int
  type        String // single_choice|multi_choice (ENUM in SQL)
  body        String  @db.Text
  options     Json
  correct     Json
  explanation String? @db.Text
  points      Int     @default(1)

  @@index([testId])
}

model LearningTestResult {
  id             String   @id @default(cuid())
  userId         String
  testId         String
  categoryId     String
  attemptNumber  Int      @default(1)
  score          Int
  maxScore       Int
  percent        Int
  correctCount   Int
  totalQuestions Int
  passed         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([testId])
}
