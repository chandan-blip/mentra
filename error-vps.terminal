root@vmi3152740:/opt/mentra# DBURL=$(grep -E '^DATABASE_URL=' /srv/mentra/.env | cut -d= -f2- | tr -d '"')
eval $(echo "$DBURL" | sed -E 's#mysql://([^:]+):([^@]+)@([^:/]+):?([0-9]*)/([^?]+).*#DBU=\1 DBP=\2 DBH=\3 DBPORT=\4 DBN=\5#')
: "${DBPORT:=3306}"
echo "DB = $DBN @ $DBH:$DBPORT"

echo; echo "===== LAST 8 LIVE SESSIONS (recording state) ====="
mysql -u"$DBU" -p"$DBP" -h"$DBH" -P"$DBPORT" "$DBN" -e "
SELECT id, status, source, recordingStatus, egressId,
       LEFT(recordingUrl,45) AS recURL, startedAt, endedAt
FROM LiveSession ORDER BY createdAt DESC LIMIT 8\G"

echo; echo "===== API LOG — full session lifecycle (last 3000 lines) ====="
journalctl -u mentra-api -n 3000 --no-pager 2>/dev/null \
  | grep -iE 'live session (started|ended)|recording egress|failed to (start|stop) recording|egress' \
  | tail -30 || echo 'NONE — no session has started/egress attempted in this window'

echo; echo "===== recent egress ACTIVITY (non-memory-stats) ====="
journalctl -u mentra-egress -n 2000 --no-pager 2>/dev/null \
  | grep -ivE 'stats/monitor|current memory usage' | tail -25
