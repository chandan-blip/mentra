root@vmi3152740:/opt/mentra# echo "===== SERVICES ====="; \
for s in mentra-api mentra-worker mentra-egress redis-server livekit; do \
  printf '%-16s ' "$s:"; systemctl is-active "$s" 2>/dev/null || echo '(not found)'; done; \
echo; echo "===== EGRESS BINARY ====="; \
ls -l /usr/local/bin/egress 2>/dev/null || echo 'MISSING — egress never built → recording cannot start'; \
echo; echo "===== EGRESS LOG (last 40) ====="; \
journalctl -u mentra-egress -n 40 --no-pager 2>/dev/null || echo 'no egress unit/log'; \
echo; echo "===== API LOG: recording/egress lines ====="; \
journalctl -u mentra-api -n 300 --no-pager 2>/dev/null | grep -iE 'egress|recording|r2 ' | tail -30 || echo 'none'; \
echo; echo "===== ENV (presence only, no secrets) ====="; \
for k in LIVEKIT_URL LIVEKIT_WS_URL LIVEKIT_API_KEY LIVEKIT_API_SECRET R2_ENDPOINT R2_BUCKET R2_ACCESS_KEY_ID R2_SECRET_ACCESS_KEY R2_PUBLIC_BASE_URL; do \
  v=$(grep -E "^$k=" /srv/mentra/.env 2>/dev/null | cut -d= -f2-); \
  if [ -n "$v" ]; then echo "$k = SET (${#v} chars)"; else echo "$k = MISSING/empty"; fi; done; \
echo; echo "===== SFU + Chrome reachability ====="; \
(command -v google-chrome >/dev/null && google-chrome --version) || echo 'google-chrome NOT installed (egress needs it)'; \
(ss -ltnp 2>/dev/null | grep -E ':7880' || echo 'nothing listening on :7880 (SFU/LiveKit down?)')
