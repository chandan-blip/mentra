  | grep -A22 "failed to start recording egress" | tail -30

echo; echo "===== B) LiveKit SERVER config location ====="
systemctl cat livekit 2>/dev/null | grep -iE 'ExecStart|--config|WorkingDirectory'
LKCFG=$(find /etc /opt /srv /root /usr/local/etc -maxdepth 4 -iname 'livekit*.y*ml' 2>/dev/null | head)
echo "config files found: $LKCFG"

echo; echo "===== C) Does LiveKit server share Redis + keys with egress? ====="
for f in $LKCFG; do
  echo "--- $f ---"
  # show redis block + key names only (mask secrets)
  grep -nE 'redis|address|^keys|^ *[A-Za-z0-9_]+:' "$f" | grep -iE 'redis|address|keys|port|:$' | head -20
done
