[Unit]
Description=Mentra API (Node/Express)
After=network.target mysql.service redis-server.service
Wants=mysql.service redis-server.service

[Service]
Type=simple
User=mentra
WorkingDirectory=/srv/mentra/apps/api
EnvironmentFile=/srv/mentra/.env
ExecStart=/usr/bin/node dist/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
