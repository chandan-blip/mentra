# Mentra native runtime env — copied to /srv/mentra/.env on first provision and
# loaded by the systemd service (EnvironmentFile) and the build/migrate steps.
# Edit values, then re-run deploy.sh (or restart mentra-api).

NODE_ENV=production
API_PORT=4000

# Public origin the browser uses (nginx). The web is built to call same-origin /api.
WEB_APP_ORIGIN=http://localhost:8080

# Local services (native, on the same host).
DATABASE_URL=mysql://mentra:mentra_dev_pw@127.0.0.1:3306/mentra
REDIS_URL=redis://127.0.0.1:6379

# Secrets — CHANGE for production (must be ≥ the lengths the schema requires).
JWT_ACCESS_SECRET=dev_access_secret_change_me_at_least_64_chars_xxxxxxxxxxxxxxxxxxx
JWT_REFRESH_COOKIE_SECRET=dev_refresh_secret_change_me_at_least_64_chars_xxxxxxxxxxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

RESUME_STORAGE_DIR=/srv/mentra/var/uploads
PROFILE_DEFAULT_TIMEZONE=Asia/Kolkata

# AI (Groq, OpenAI-compatible). REQUIRED — the API refuses to boot without it
# (env schema enforces min length 1). Replace with your own key for production.
AI_API_KEY=gsk_your_groq_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
ROADMAP_GENERATOR_STRATEGY=ai

# LiveKit (native binary on this host). LIVEKIT_URL = control plane; LIVEKIT_WS_URL =
# what the browser connects to (proxied by nginx at /rtc). Keys must match livekit.yaml.
LIVEKIT_URL=http://127.0.0.1:7880
LIVEKIT_WS_URL=ws://localhost:8080
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_chars_xxxx
LIVEKIT_TOKEN_TTL_SECONDS=21600

# Recordings storage — Cloudflare R2 (S3-compatible). From R2 → Manage R2 API Tokens
# (Object Read & Write, scoped to the bucket). Region is always 'auto'. R2_PUBLIC_BASE_URL
# = public CDN custom domain serving HLS. Empty = recordings disabled. Secrets go in .env.
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mentra-recordings
R2_PUBLIC_BASE_URL=

# Marketing — LinkedIn OAuth (optional; empty = disabled).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8080/api/v1/marketing/linkedin/callback
